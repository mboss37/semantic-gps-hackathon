# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real credentials.

# Supabase (new 2026 key format: sb_publishable_* / sb_secret_*)
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Anthropic (for the demo agent)
ANTHROPIC_API_KEY=

# Anthropic model IDs — no hardcoded defaults anywhere. Set these in .env.local
# and in Vercel env. Fail-loud if missing so we never silently fall back to a
# production model during local iteration.
#   PLAYGROUND_MODEL     — A/B Playground runs. Sonnet by default — Opus is
#                          overkill here and burns cost on every pane.
#   EVALUATE_GOAL_MODEL  — evaluate_goal TRel ranker. Opus stays because
#                          reasoning quality matters for the 1M-context goal
#                          matching and this path is called rarely.
PLAYGROUND_MODEL=claude-sonnet-4-6
EVALUATE_GOAL_MODEL=claude-opus-4-7

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AES-256-GCM key for encrypting stored server credentials.
# Generate once: `openssl rand -base64 32`
CREDENTIALS_ENCRYPTION_KEY=

# Vendor MCP credentials (Sprint 15 C.6).
# The co-deployed vendor routes at app/api/mcps/<vendor>/route.ts read these
# directly from the environment — servers.auth_config is NULL for the three
# demo servers. Same vars on local AND on Vercel (all environments).

# Salesforce — OAuth 2.0 client-credentials flow against a Developer Edition
# org. Create a Connected App with "Enable Client Credentials Flow" in
# Setup → App Manager; the client_id/secret go here.
SF_LOGIN_URL=https://your-org.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# Slack — Bot token (xoxb-*) from the Slack app's OAuth & Permissions page.
# Scopes needed: chat:write, users:read.email, channels:read, chat:write.
SLACK_BOT_TOKEN=

# GitHub — classic PAT with repo scope. `owner` + `repo` come from each tool
# call's arguments, not from env; only the PAT lives here.
GITHUB_PAT=

# SSRF guard escape hatch. Set to '1' ONLY on local dev — the gateway's
# proxyHttp roundtrips through safeFetch for every upstream including the
# co-deployed vendor routes (origin_url = http://localhost:3000/...), and
# safeFetch blocks localhost by default. On Vercel the vendor origin_url is
# the live HTTPS domain and this flag stays unset (the guard accepts public
# HTTPS natively). Also used by a handful of vitest proxy suites.
SSRF_ALLOW_LOCALHOST=

# ---------------------------------------------------------------------------
# Optional runtime flags (set on Vercel if you want the behaviour, else skip)
# ---------------------------------------------------------------------------

# Feature flag: dashboard graph page's "Demo simulators" row of fake tools.
# '1' → simulator widgets render. Unset → hidden. Safe to leave blank in prod.
NEXT_PUBLIC_ENABLE_DEMO_SIMULATORS=

# Real-upstream proxy toggle. Default behaviour is REAL — set to '0' to force
# the dispatcher's mock canned data path (useful when upstream creds aren't
# wired yet). In prod this stays unset / '1'.
REAL_PROXY_ENABLED=

# Ops endpoint gate for /api/internal/manifest/invalidate. Disabled in prod
# unless explicitly '1'; dev NODE_ENV auto-enables. Leave unset on Vercel
# unless you need remote manifest-cache busting.
MANIFEST_INTROSPECTION_ENABLED=

# Explicit gateway URL override for the Playground A/B run handler. Unset →
# the handler derives from NEXT_PUBLIC_APP_URL. Set when the Playground and
# the gateway live on different hosts (e.g. tunnel'd dev).
SEMANTIC_GPS_GATEWAY_URL=

# Opt-in integration-test flags (VERIFY_ANTHROPIC / VERIFY_SALESFORCE /
# VERIFY_SLACK / VERIFY_GITHUB / VERIFY_REAL_PROXY / VERIFY_INTEGRATIONS /
# VERIFY_GATEWAY_URL) are NOT listed here on purpose — the app never reads
# them at runtime, they gate vitest suites only. Documented in README.md
# under "Integration-test flags". Never needed on Vercel.
